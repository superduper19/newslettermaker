# Server (optional)
PORT=5020
NODE_ENV=development

# AI article search & modify — use at least one
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# GOOGLE_API_KEY=   # alternative to GEMINI_API_KEY

# Freepik image search (optional if using upload-only)
FREEPIK_API_KEY=

# Supabase — from Dashboard: Settings → API → Project URL and API Keys
SUPABASE_URL=https://xxxxxxxx.supabase.co

# Use the secret key for this app (server/backend). Format: sb_secret_...
# Copy from: API Keys → Secret keys → default → copy
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Or use publishable key (sb_publishable_...) if table has GRANT to anon and you prefer no secret
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional: table name for app state (default: newsletter_state)
# SUPABASE_STATE_TABLE=newsletter_state

# Optional: direct Postgres connection (for scripts/drop-old-db.js only)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@...pooler.supabase.com:6543/postgres

# GoDaddy FTP — for publishing inspirational images
GODADDY_FTP_HOST=
GODADDY_FTP_PORT=21
GODADDY_FTP_USER=
GODADDY_FTP_PASS=
GODADDY_PUBLIC_BASE_URL=https://purablis.com/News-roundup
